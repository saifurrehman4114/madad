# Copy to .env and adjust. Never commit the real .env.

# Which backend the FastAPI server should boot.
#   ollama       - talks to a local Ollama daemon (default, fastest dev loop)
#   transformers - loads the HF model + LoRA adapter in-process (needs GPU)
MADAD_BACKEND=ollama

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=madad-gemma4:latest

# Transformers fallback
HF_MODEL_ID=google/gemma-4-e4b-it
HF_ADAPTER_PATH=training/outputs/madad-lora
HF_DEVICE=cuda

# API
MADAD_HOST=0.0.0.0
MADAD_PORT=8000
MADAD_CORS_ORIGINS=http://localhost:5173
